---
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { getUiStrings } from '../i18n/ui';
import { defaultLocale, type Locale } from '../i18n/config';
import '../styles/global.css';

interface Props {
  locale: Locale;
  camera: {
    id: string;
    data: {
      make: string;
      model: string;
      format: string;
      status: 'confirmed' | 'expected' | 'unsupported';
      mechanism: string;
      ratedShutterLife: number | null;
      notes: string | null;
    };
  };
}

const { locale, camera } = Astro.props;
const t = getUiStrings(locale);
const { make, model, format, status, mechanism, ratedShutterLife, notes } = camera.data;

const base = import.meta.env.BASE_URL;
const localePrefix = locale === defaultLocale ? '' : `${locale}/`;
const homeHref = `${base}${localePrefix}`;
const localeTag: Record<Locale, string> = { en: 'en-US', es: 'es-ES', de: 'de-DE', fr: 'fr-FR', ja: 'ja-JP' };

const statusCopy = {
  confirmed: t.confirmedCopy(format),
  expected: t.expectedCopy,
  // Per-camera investigative notes are only written in English — translating 140+ entries'
  // worth of specific technical commentary isn't practical yet, so this one field stays as-is
  // across locales rather than being silently blank.
  unsupported: notes ?? t.unsupportedCopy,
};

const title = `${make} ${model} ${t.cameraPageTitleSuffix}`;
const description =
  status === 'unsupported'
    ? `${make} ${model} — ${t.camerasPageDescription}`
    : t.mechanismCopy({ makeModel: `${make} ${model}`, mechanism, format });
---

<html lang={locale}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<main>
			<header class="site-header">
				<p class="breadcrumb"><a href={homeHref}>TrueShutter</a> / {t.camerasPageTitle} / {make} {model}</p>
				<h1>{make} {model} {t.cameraPageTitleSuffix}</h1>
				<p class={`status-badge status-badge--${status}`}>
					{status === 'confirmed' && t.statusConfirmed}
					{status === 'expected' && t.statusExpected}
					{status === 'unsupported' && t.statusUnsupported}
				</p>
			</header>

			<section class="camera-detail panel">
				<p>{statusCopy[status]}</p>

				{status !== 'unsupported' && (
					<>
						<p>{t.mechanismCopy({ makeModel: `${make} ${model}`, mechanism, format })}</p>
						<a class="cta" href={homeHref}>
							{t.checkCameraCta(model)}
						</a>
					</>
				)}

				{ratedShutterLife && (
					<p>{t.ratedLifeCopy({ model, life: ratedShutterLife.toLocaleString(localeTag[locale]) })}</p>
				)}
			</section>

			<footer class="site-footer">
				<p><a href={`${base}${localePrefix}cameras`}>{t.allSupportedCameras}</a></p>
				<a class="coffee-link" href="https://buymeacoffee.com/mertozdogan" target="_blank" rel="noopener noreferrer">
					{t.coffeeLink}
				</a>
				<LanguageSwitcher locale={locale} path={`cameras/${camera.id}`} />
			</footer>
		</main>
	</body>
</html>

<style>
	.breadcrumb {
		font-size: 0.85rem;
		opacity: 0.85;
		margin: 0 0 0.5rem;
	}
	.status-badge {
		display: inline-block;
		font-weight: 800;
		font-size: 0.8rem;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		padding: 0.35rem 0.9rem;
		border-radius: 999px;
		border: 3px solid var(--ink);
	}
	.status-badge--confirmed {
		background: var(--mint);
		color: var(--ink);
	}
	.status-badge--expected {
		background: var(--bg-elevated);
		color: var(--text-dim);
	}
	.status-badge--unsupported {
		background: var(--pink);
		color: #fff;
	}
	.camera-detail {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.cta {
		display: inline-block;
		color: #fff;
		background: var(--blue);
		font-weight: 800;
		padding: 0.7rem 1.3rem;
		border-radius: 10px;
		border: 3px solid var(--ink);
		box-shadow: 5px 5px 0 var(--ink);
		text-decoration: none;
		width: fit-content;
		transition: transform 0.1s ease, box-shadow 0.1s ease;
	}
	.cta:hover {
		transform: translate(-2px, -2px);
		box-shadow: 7px 7px 0 var(--ink);
	}
</style>
