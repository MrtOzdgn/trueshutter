---
import { getCollection } from 'astro:content';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { getUiStrings } from '../i18n/ui';
import { defaultLocale, type Locale } from '../i18n/config';
import '../styles/global.css';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getUiStrings(locale);
const base = import.meta.env.BASE_URL;
const localePrefix = locale === defaultLocale ? '' : `${locale}/`;
const homeHref = `${base}${localePrefix}`;

const cameras = await getCollection('cameras');

const byMake = new Map<string, typeof cameras>();
for (const camera of cameras) {
  const list = byMake.get(camera.data.make) ?? [];
  list.push(camera);
  byMake.set(camera.data.make, list);
}
const makes = [...byMake.keys()].sort();

const statusIcon = { confirmed: '✓', expected: '◐', unsupported: '✗' } as const;
---

<html lang={locale}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={t.camerasPageDescription} />
		<title>{t.camerasPageTitle} — TrueShutter</title>
	</head>
	<body>
		<main>
			<header class="site-header">
				<p class="breadcrumb"><a href={homeHref}>TrueShutter</a> / {t.camerasPageTitle}</p>
				<h1>{t.camerasPageTitle}</h1>
				<p>{t.camerasLegend}</p>
			</header>

			<div class="panel">
				{makes.map((make) => (
					<section class="make-group">
						<h2>{make}</h2>
						<ul class="camera-list">
							{byMake
								.get(make)!
								.sort((a, b) => a.data.model.localeCompare(b.data.model))
								.map((camera) => (
									<li>
										<a href={`${base}${localePrefix}cameras/${camera.id}`}>
											<span class={`status-icon status-icon--${camera.data.status}`}>{statusIcon[camera.data.status]}</span>
											{camera.data.model}
										</a>
									</li>
								))}
						</ul>
					</section>
				))}
			</div>

			<footer class="site-footer">
				<p><a href={homeHref}>{t.backToTool}</a></p>
				<LanguageSwitcher locale={locale} path="cameras" />
			</footer>
		</main>
	</body>
</html>

<style>
	.breadcrumb {
		font-size: 0.85rem;
		opacity: 0.85;
		margin: 0 0 0.5rem;
	}
	.make-group {
		margin-bottom: 2rem;
	}
	.make-group:last-child {
		margin-bottom: 0;
	}
	.make-group h2 {
		font-size: 1.1rem;
		font-weight: 900;
		border-bottom: 3px solid var(--ink);
		padding-bottom: 0.5rem;
	}
	.camera-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
		gap: 0.6rem;
	}
	.camera-list a {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--text);
		text-decoration: none;
		font-weight: 700;
		padding: 0.55rem 0.85rem;
		border-radius: 10px;
		border: 3px solid var(--ink);
		background: var(--bg-elevated);
		transition: transform 0.1s ease, box-shadow 0.1s ease;
	}
	.camera-list a:hover {
		box-shadow: 4px 4px 0 var(--ink);
		transform: translate(-2px, -2px);
	}
	.status-icon--confirmed {
		color: var(--ok);
	}
	.status-icon--expected {
		color: var(--text-dim);
	}
	.status-icon--unsupported {
		color: var(--error);
	}
</style>
