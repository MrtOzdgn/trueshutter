---
import { getCollection } from 'astro:content';
import CameraDetailPage from '../../layouts/CameraDetailPage.astro';

export async function getStaticPaths() {
  const cameras = await getCollection('cameras');
  return cameras.map((camera) => ({
    params: { id: camera.id },
    props: { camera },
  }));
}

const { camera } = Astro.props;
---

<CameraDetailPage locale="en" camera={camera} />
