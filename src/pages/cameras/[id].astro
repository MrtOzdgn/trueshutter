---
import { getCollection } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
  const cameras = await getCollection('cameras');
  return cameras.map((camera) => ({
    params: { id: camera.id },
    props: { camera },
  }));
}

const { camera } = Astro.props;
const { make, model, format, status, mechanism, ratedShutterLife, notes } = camera.data;

const statusCopy = {
  confirmed: `We've tested this exact camera against a real ${format} sample file and independently verified the shutter count against exiftool — this one is confirmed working.`,
  expected: `This camera hasn't been personally tested here yet, but it shares its metadata layout with a sibling model we have confirmed, so it's expected to work the same way.`,
  unsupported: notes ?? `We don't yet support reading shutter count for this camera.`,
};

const title = `${make} ${model} Shutter Count — How to Check It`;
const description =
  status === 'unsupported'
    ? `Can you check the ${make} ${model} shutter count from a file? Here's why this one is different, and what to do instead.`
    : `Check your ${make} ${model} shutter count instantly and privately — drop a ${format} file in your browser, nothing is uploaded.`;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<main>
			<header class="site-header">
				<p class="breadcrumb"><a href={import.meta.env.BASE_URL}>TrueShutter</a> / Cameras / {make} {model}</p>
				<h1>{make} {model} Shutter Count</h1>
				<p class={`status-badge status-badge--${status}`}>
					{status === 'confirmed' && '✓ Confirmed'}
					{status === 'expected' && '◐ Expected to work'}
					{status === 'unsupported' && '✗ Not supported'}
				</p>
			</header>

			<section class="camera-detail">
				<p>{statusCopy[status]}</p>

				{status !== 'unsupported' && (
					<>
						<p>
							Shutter count for the {make} {model} is read from <code>{mechanism}</code> in the camera's{' '}
							{format} file metadata — entirely in your browser, the file is never uploaded anywhere.
						</p>
						<a class="cta" href={import.meta.env.BASE_URL}>
							Check your {model} shutter count →
						</a>
					</>
				)}

				{ratedShutterLife && (
					<p>
						Canon, Nikon, Sony and Fujifilm publish a rated shutter durability for most bodies — for the {model}, that
						figure is approximately <strong>{ratedShutterLife.toLocaleString()} actuations</strong>. This is a
						statistical durability rating from the manufacturer, not a hard limit — many shutters keep working well
						past it, and some fail earlier.
					</p>
				)}
			</section>

			<footer class="site-footer">
				<p><a href={`${import.meta.env.BASE_URL}cameras`}>← All supported cameras</a></p>
				<a class="coffee-link" href="https://buymeacoffee.com/mertozdogan" target="_blank" rel="noopener noreferrer">
					☕ Buy me a coffee
				</a>
			</footer>
		</main>
	</body>
</html>

<style>
	.breadcrumb {
		color: var(--text-dim);
		font-size: 0.85rem;
	}
	.breadcrumb a {
		color: inherit;
	}
	.status-badge {
		display: inline-block;
		font-weight: 600;
		padding: 0.25rem 0.75rem;
		border-radius: 999px;
		border: 1px solid var(--border);
	}
	.status-badge--confirmed {
		color: var(--ok);
		border-color: var(--ok);
	}
	.status-badge--expected {
		color: var(--text-dim);
	}
	.status-badge--unsupported {
		color: var(--error);
		border-color: var(--error);
	}
	.camera-detail {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		background: var(--bg-elevated);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 1.5rem;
	}
	.camera-detail code {
		font-family: ui-monospace, monospace;
		background: var(--bg);
		padding: 0.1rem 0.4rem;
		border-radius: 4px;
	}
	.cta {
		display: inline-block;
		color: var(--bg);
		background: var(--accent);
		font-weight: 700;
		padding: 0.6rem 1.1rem;
		border-radius: 8px;
		text-decoration: none;
		width: fit-content;
	}
</style>
