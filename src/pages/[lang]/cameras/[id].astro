---
import { getCollection } from 'astro:content';
import CameraDetailPage from '../../../layouts/CameraDetailPage.astro';
import { locales, defaultLocale, type Locale } from '../../../i18n/config';

export async function getStaticPaths() {
  const cameras = await getCollection('cameras');
  const langs = locales.filter((l) => l !== defaultLocale);
  return langs.flatMap((lang) =>
    cameras.map((camera) => ({
      params: { lang, id: camera.id },
      props: { camera },
    })),
  );
}

const lang = Astro.params.lang as Locale;
const { camera } = Astro.props;
---

<CameraDetailPage locale={lang} camera={camera} />
